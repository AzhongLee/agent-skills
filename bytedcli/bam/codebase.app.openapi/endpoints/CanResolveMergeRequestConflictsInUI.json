  "resp_schema": {
    "200": {
      "body_param": {
        "Allowed": {
          "type": "bool",
          "desc": "Whether current user can resolve the merge request conflict in UI.\n\n`Allowed` being true means that the conflict must satisfy all of the following conditions:\n\n1. merge request should be `open`.\n2. the `merge_method` of MergeRequest should be `merge_commit` if  `change_mode` is `branch`.\n3. user has write access to repo and has push access to the source branch.\n4. conflicts should exist.\n5. each file in the conflict should satisfy:\n5.1. Is a non binary text file.\n5.2. Is less than 200 KB in size with conflict markers added.\n5.3. Uses UTF-8 compatible encoding.\n5.4. Doesn't contain conflict markers.\n5.5. Exists under the same path in both branches.",
          "raw_name": "Allowed",
          "raw_type": "bool",
          "field_id": 1,
          "optional": null,
          "raw_optional": null,
          "ref_name": null
        },
        "Reason": {
          "type": "string",
          "desc": "Reason why conflicts can't be resolved in UI, required if `Allowed` is false.",
